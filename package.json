{
  "name": "@sovorn/pi-profile",
  "version": "0.4.5",
  "description": "Hermes-style isolated profiles with persistent memory for the Pi coding agent",
  "type": "module",
  "bin": {
    "pi-profile": "dist/cli.js"
  },
  "files": [
    "dist/",
    "src/",
    "skills/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run build && tsx --test test/core.test.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "profiles",
    "memory",
    "cli"
  ],
  "author": "Sovorn C <cheasovorn4@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sovorn-c/pi-profile.git"
  },
  "homepage": "https://github.com/sovorn-c/pi-profile#readme",
  "bugs": {
    "url": "https://github.com/sovorn-c/pi-profile/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typebox": "^1.3.6",
    "typescript": "^5.9.3"
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  }
}
